{
  "name": "messenger-self-chat",
  "version": "1.0.0",
  "description": "Electron desktop app — Messenger-style self chat / private notebook.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.messenger.selfchat",
    "productName": "Messenger Self-Chat",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.js",
      "styles.css",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Messenger Self-Chat"
    }
  },
  "keywords": [
    "messenger",
    "electron",
    "notes",
    "self-chat",
    "journal"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "engines": {
    "node": ">=18"
  }
}
